sinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/824570/extras/c3c6471465db57ff9218c6fc3044b216.poster.avif?t=1744973658\" width=550 height=224 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/824570/extras/c3c6471465db57ff9218c6fc3044b216.webm?t=1744973658\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/824570/extras/c3c6471465db57ff9218c6fc3044b216.mp4?t=1744973658\" type=\"video/mp4\"></video></span><br><br><ul class=\"bb_ul\"><li> Award-winning soundtrack!<br></li><li> Over 120 unique puzzles!<br></li><li> Quirky yellow robots!</li></ul>",
