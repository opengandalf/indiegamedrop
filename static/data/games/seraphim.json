i></ul><br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2594690/extras/fdccb3a1e5c3ca9ac893d569c5f536ca.poster.avif?t=1708626785\" width=622 height=188 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2594690/extras/fdccb3a1e5c3ca9ac893d569c5f536ca.webm?t=1708626785\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2594690/extras/fdccb3a1e5c3ca9ac893d569c5f536ca.mp4?t=1708626785\" type=\"video/mp4\"></video></span>",
