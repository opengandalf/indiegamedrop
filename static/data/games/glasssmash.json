play muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1052220/extras/2546c084fc65e5c73522ebcfc16342e6.poster.avif?t=1764941477\" width=480 height=300 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1052220/extras/2546c084fc65e5c73522ebcfc16342e6.webm?t=1764941477\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1052220/extras/2546c084fc65e5c73522ebcfc16342e6.mp4?t=1764941477\" type=\"video/mp4\"></video></span>",
