mg\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/938560/extras/de27865282145bdf7b31dd60254056d6.poster.avif?t=1768501017\" width=780 height=200 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/938560/extras/de27865282145bdf7b31dd60254056d6.webm?t=1768501017\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/938560/extras/de27865282145bdf7b31dd60254056d6.mp4?t=1768501017\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><picture><source srcset=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/938560/extras/01d0eec128cccc3037cb397d8ae55d7e.apng?t=1768501017\"><img src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/938560/extras/01d0eec128cccc3037cb397d8ae55d7e.poster.avif?t=1768501017\" class=\"bb_img\" width=780 height=100 /></picture></span></p>",
