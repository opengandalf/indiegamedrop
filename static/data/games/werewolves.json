tatic.com/store_item_assets/steam/apps/2564770/extras/a33a977d5dc6893262bb84c4290d0a09.poster.avif?t=1716425337\" width=640 height=360 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2564770/extras/a33a977d5dc6893262bb84c4290d0a09.webm?t=1716425337\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2564770/extras/a33a977d5dc6893262bb84c4290d0a09.mp4?t=1716425337\" type=\"video/mp4\"></video></span>",
