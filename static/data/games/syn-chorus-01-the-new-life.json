c93bb186bf7933ca522.webm?t=1764223331\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2730530/extras/905700b994998c93bb186bf7933ca522.mp4?t=1764223331\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2730530/extras/52224ec41cd3b27d7ea10384e5d32fbe.avif?t=1764223331\" width=616 height=107 /></span></p><p class=\"bb_paragraph\" >游戏中最重要的活动——“城市复兴大赛”！这场数年一度的大竞赛，旨在选拔文明重建的年轻英才。</p><p class=\"bb_paragraph\" >赛中包含“生产、建设、环保、治安、文化”等多种生活课题，寻觅、集结和游说城市中的各类英才，一起赢下比赛吧！</p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2730530/extras/b04510ebcdb522d17ba29093c36adef6.poster.avif?t=1764223331\" width=616 height=346 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2730530/extras/b04510ebcdb522d17ba29093c36adef6.webm?t=1764223331\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2730530/extras/b04510ebcdb522d17ba29093c36adef6.mp4?t=1764223331\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" >天灾中幸存的后末日城市，依然处处物资短缺，</p><p class=\"bb_paragraph\" >将都市边缘的废弃工厂改造为生产基地，耕作、制造、探险，勤劳致富从此开始。</p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2730530/extras/cc5dc4a05d9242be2482ae31cf2cb6c1.poster.avif?t=1764223331\" width=616 height=346 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2730530/extras/cc5dc4a05d9242be2482ae31cf2cb6c1.webm?t=1764223331\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_asse