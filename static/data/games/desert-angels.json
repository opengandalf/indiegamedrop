class=\"bb_paragraph\" style=\"text-align: center\"><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3048770/extras/8320f7195b28dc9e919a89ff07b8fc12.poster.avif?t=1758659206\" width=616 height=308 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3048770/extras/8320f7195b28dc9e919a89ff07b8fc12.webm?t=1758659206\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3048770/extras/8320f7195b28dc9e919a89ff07b8fc12.mp4?t=1758659206\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" ></p>",
