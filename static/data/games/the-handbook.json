9.poster.avif?t=1743038979\" width=800 height=224 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1637520/extras/2d8d2a7d667982bf283beb6c96489d59.webm?t=1743038979\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1637520/extras/2d8d2a7d667982bf283beb6c96489d59.mp4?t=1743038979\" type=\"video/mp4\"></video></span></p>",
