ai.steamstatic.com/store_item_assets/steam/apps/2467210/extras/408a56764dc8c37eac83fc72e77a4ee7.poster.avif?t=1690941078\" width=384 height=216 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2467210/extras/408a56764dc8c37eac83fc72e77a4ee7.webm?t=1690941078\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2467210/extras/408a56764dc8c37eac83fc72e77a4ee7.mp4?t=1690941078\" type=\"video/mp4\"></video></span><br><br><i>If your rank reaches \"Master\" or above and you are in the top three of the leaderboard, you will receive a special title.</i>",
