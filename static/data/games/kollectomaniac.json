/steam/apps/3491740/extras/f4c525b3f451a04866f31a2f4f9b9c51.poster.avif?t=1773771388\" width=1170 height=658 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3491740/extras/f4c525b3f451a04866f31a2f4f9b9c51.webm?t=1773771388\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3491740/extras/f4c525b3f451a04866f31a2f4f9b9c51.mp4?t=1773771388\" type=\"video/mp4\"></video></span></p><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" >Play risky games in the grove after unlocking <i>Noise</i>, letting you bet your hard-earned cents on fantastic games.</p></li><li><p class=\"bb_paragraph\" >Sell your organs to pay off debts or go all in by talking to <i>Noise</i>.</p></li></ul><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3491740/extras/774ffd79fb7e8b369021e5cd1821ece9.avif?t=1773771388\" width=1560 height=219 /></span><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3491740/extras/0ff3acbacb5cbfb2253a9b696b6611d6.poster.avif?t=1773771388\" width=1170 height=658 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3491740/extras/0ff3acbacb5cbfb2253a9b696b6611d6.webm?t=1773771388\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3491740/extras/0ff3acbacb5cbfb2253a9b696b6611d6.mp4?t=1773771388\" type=\"video/mp4\"></video></span></p><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" >Solve simple puzzles in the grove to earn cents! Later updates will add more puzzles and minigames.</p></li></ul><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3491740/extras/21a0cca70fe4dbcaef9a0fcb97407152.avif?t=1773771388\" width=1560 height=219 /></span><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3491740/extras/f5fb66aaa37dfcbc6f21e5b17712f12c.poster.avif?t=1773771388\" width=1170 height=658 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3491740/extras/f5fb66aaa37dfcbc6f21e5b17712f12c.webm?t=1773771388\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3491740/extras/f5fb66aaa37dfcbc6f21e5b17712f12c.mp4?t=1773771388\" type=\"video/mp4\"></video></span></p><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" >Unlock a game console and game cartridges by making soup in the grove; Unlocking an alternate way to end days with a bit of gaming.</p></li></ul><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3491740/extras/8d9b756cd77cba9eb2c2002711357496.avif?t=1773771388\" width=1560 height=219 /></span><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3491740/extras/8f7d2e84d69bbb2eb70aadb8cac90c8b.poster.avif?t=1773771388\" width=1170 height=658 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3491740/extras/8f7d2e84d69bbb2eb70aadb8cac90c8b.webm?t=1773771388\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3491740/extras/8f7d2e84d69bbb2eb70aadb8cac90c8b.mp4?t=1773771388\" type=\"video/mp4\"></video></span></p><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" >Every four days, you must pay your landlord to survive. Keep him happy or else...</p></li></ul><p class=\"bb_paragraph\" style=\"text-align: center\"><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3491740/extras/eb2d24448483a85fc3c269ad0a6d2b3a.avif?t=1773771388\" width=1560 height=221 /></span><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3491740/extras/7a941ac3ef78dbd7069154039e98a654.avif?t=1773771388\" width=1560 height=175 /></span><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3491740/extras/310dbaecce40baf70a569908abe55dbc.avif?t=1773771388\" width=1560 height=406 /></span></p>",
