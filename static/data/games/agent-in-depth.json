s://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2096080/extras/b1484760557971e0e8d4d3c4d0013cf7.poster.avif?t=1763473553\" width=600 height=338 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2096080/extras/b1484760557971e0e8d4d3c4d0013cf7.webm?t=1763473553\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2096080/extras/b1484760557971e0e8d4d3c4d0013cf7.mp4?t=1763473553\" type=\"video/mp4\"></video></span></p>",
