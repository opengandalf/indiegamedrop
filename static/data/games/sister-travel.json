  "detailed_description": "<p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/959890/extras/7648cd7a13433ec27402709a5996df62.avif?t=1749385138\" width=576 height=324 /></span></p><p class=\"bb_paragraph\" >A Dungeon Crawling-Choose Your Adventure-type RPG is here!</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" >A heart-pounding thrill ride that you’ll never forget!</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" >Treasures are hidden away inside ancient ruins.</p><p class=\"bb_paragraph\" >Nail-biting battles against monsters.</p><p class=\"bb_paragraph\" >Yearning for a land unseen.</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" >An adventurer. And his sister-like companions.</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" >Enjoy this adventure filled with romance and epic fight scenes!</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><strong>Experience this masterful blend of action and romance brought to you in native English!</strong></p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" >Features</p><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" ><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" >A Dungeon-Crawling-Choose Your Own Adventure-type RPG</p></li></ul><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" >An Elaborate, Hand-drawn World Map</p></li></ul><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" >A Large Ensemble Cast of Characters</p></li></ul><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" >Tons of Fight Scenes</p></li></ul></p></li></ul>",
  "about_the_game": "<p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/959890/extras/7648cd7a13433ec27402709a5996df62.avif?t=1749385138\" width=576 height=324 /></span></p><p class=\"bb_paragraph\" >A Dungeon Crawling-Choose Your Adventure-type RPG is here!</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" >A heart-pounding thrill ride that you’ll never forget!</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" >Treasures are hidden away inside ancient ruins.</p><p class=\"bb_paragraph\" >Nail-biting battles against monsters.</p><p class=\"bb_paragraph\" >Yearning for a land unseen.</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" >An adventurer. And his sister-like companions.</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" >Enjoy this adventure filled with romance and epic fight scenes!</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><strong>Experience this masterful blend of action and romance brought to you in native English!</strong></p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" >Features</p><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" ><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" >A Dungeon-Crawling-Choose Your Own Adventure-type RPG</p></li></ul><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" >An Elaborate, Hand-drawn World Map</p></li></ul><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" >A Large Ensemble Cast of Characters</p></li></ul><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" >Tons of Fight Scenes</p></li></ul></p></li></ul>",
