ted loop playsinline crossorigin=\"anonymous\" poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1262060/extras/4d8722f8413b6719d0ea6baeab1482c0.poster.avif?t=1735317473\" width=600 height=136 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1262060/extras/4d8722f8413b6719d0ea6baeab1482c0.webm?t=1735317473\" type=\"video/webm; codecs=vp9\"></video></span>",
