441599a0a74c1684.poster.avif?t=1696932509\" width=600 height=284 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1628890/extras/7c7453921d471d0c441599a0a74c1684.webm?t=1696932509\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1628890/extras/7c7453921d471d0c441599a0a74c1684.mp4?t=1696932509\" type=\"video/mp4\"></video></span><br><br></li><li>Guardians of great stature and power will also stand in your way. Our hero must find ways to bring down these towering terrors! But just so you know, there is no violence or combat in this game! NecroBoy is just a kid, godammit.<br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1628890/extras/ebc05dd971299e9337f3b603ffab0f49.poster.avif?t=1696932509\" width=600 height=284 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1628890/extras/ebc05dd971299e9337f3b603ffab0f49.webm?t=1696932509\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1628890/extras/ebc05dd971299e9337f3b603ffab0f49.mp4?t=1696932509\" type=\"video/mp4\"></video></span><br><br></li><li>Should you bring to heel these fearsome foes, you may get a special new skin for your minions. There are 8 ways to dress up your spirit servants and some will require you venturing down secret paths.<br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1628890/extras/f5dbddc4b8129a9fb9a58d5ca3c4c340.poster.avif?t=1696932509\" width=600 height=328 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1628890/extras/f5dbddc4b8129a9fb9a58d5ca3c4c340.webm?t=1696932509\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1628890/extras/f5dbddc4b8129a9fb9a58d5ca3c4c340.mp4?t=1696932509\" type=\"video/mp4\"></video></span></li></ul><h2 class=\"bb_tag\" ><strong>For Steam Deck Users</strong></h2><strong>A fix for Steam Deck is coming soon. Thank you for your patience.</strong>",
