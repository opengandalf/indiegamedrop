2343930/extras/d58afc72ff540815fc02aaef940ff83b.poster.avif?t=1757920805\" width=600 height=338 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2343930/extras/d58afc72ff540815fc02aaef940ff83b.webm?t=1757920805\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2343930/extras/d58afc72ff540815fc02aaef940ff83b.mp4?t=1757920805\" type=\"video/mp4\"></video></span></p>",
