e poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1569750/extras/e5ff3c9ea607e3ec962000b213211bc6.poster.avif?t=1734451606\" width=750 height=422 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1569750/extras/e5ff3c9ea607e3ec962000b213211bc6.webm?t=1734451606\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1569750/extras/e5ff3c9ea607e3ec962000b213211bc6.mp4?t=1734451606\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" >>> Content</p><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" >About 1.5 hours of playtime</p></li><li><p class=\"bb_paragraph\" >60+ levels</p></li></ul>",
