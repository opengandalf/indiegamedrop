976e5de4026f1a4a64843.poster.avif?t=1620669585\" width=570 height=300 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1391220/extras/faf14dcf697976e5de4026f1a4a64843.webm?t=1620669585\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1391220/extras/faf14dcf697976e5de4026f1a4a64843.mp4?t=1620669585\" type=\"video/mp4\"></video></span><br><br>Build and improve your bases! Produce and store electrical energy. Be prepared for enemy raids! Each biome allows you to build various unique items.<br><br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1391220/extras/a91c0ab9a475f93b18504822df17ed93.poster.avif?t=1620669585\" width=570 height=300 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1391220/extras/a91c0ab9a475f93b18504822df17ed93.webm?t=1620669585\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1391220/extras/a91c0ab9a475f93b18504822df17ed93.mp4?t=1620669585\" type=\"video/mp4\"></video></span><br><br>Create and improve your equipment. A good weapon and armor will help you survive, but when your opponent is much stronger than you - better run away!",
