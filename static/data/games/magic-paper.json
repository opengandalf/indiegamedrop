ai.steamstatic.com/store_item_assets/steam/apps/2387310/extras/65b5ddbf57d05ddca429668295c83a1e.webm?t=1721297192\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2387310/extras/65b5ddbf57d05ddca429668295c83a1e.mp4?t=1721297192\" type=\"video/mp4\"></video></span><br><i><strong>You can explore dungeons with unique monsters and bosses.</strong></i><br><br><br>You can teleport to the room you passed by by clicking the icon on the minimap.<br><br><br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2387310/extras/814f6c3be66176d8c6cfc2dec1390d1b.poster.avif?t=1721297192\" width=600 height=338 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2387310/extras/814f6c3be66176d8c6cfc2dec1390d1b.webm?t=1721297192\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2387310/extras/814f6c3be66176d8c6cfc2dec1390d1b.mp4?t=1721297192\" type=\"video/mp4\"></video></span><br>In the dungeon, you can trade with goblins who sell potions and magic pieces.<br><br><br>Collect gems from bosses and enter the Devil Castle to defeat the Dark Lord!<br><br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2387310/extras/a1a07f20040e8f2c251d88df23dfa286.poster.avif?t=1721297192\" width=600 height=338 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2387310/extras/a1a07f20040e8f2c251d88df23dfa286.webm?t=1721297192\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2387310/extras/a1a07f20040e8f2c251d88df23dfa286.mp4?t=1721297192\" type=\"video/mp4\"></video></span>",
