76d5c5cd1626e421e3c490b333fb.poster.avif?t=1749636719\" width=600 height=338 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2719130/extras/439c76d5c5cd1626e421e3c490b333fb.webm?t=1749636719\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2719130/extras/439c76d5c5cd1626e421e3c490b333fb.mp4?t=1749636719\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><strong>-Present evidence-</strong></p><p class=\"bb_paragraph\" >Carefully observe every piece of evidence in the case, present evidence that contradicts the opponent's speech, and shatter the opponent's logic!</p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2719130/extras/a870fcafdd0a71e606da14d7fa06bcc7.poster.avif?t=1749636719\" width=600 height=338 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2719130/extras/a870fcafdd0a71e606da14d7fa06bcc7.webm?t=1749636719\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2719130/extras/a870fcafdd0a71e606da14d7fa06bcc7.mp4?t=1749636719\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><strong>-Restore the truth-</strong></p><p class=\"bb_paragraph\" >Combine the story fragments and restore the truth of the incident!</p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2719130/extras/4f0a13d8f4f6ed64ed3f6c0e38af3efb.poster.avif?t=1749636719\" width=600 height=338 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2719130/extras/4f0a13d8f4f6ed64ed3f6c0e38af3efb.webm?t=1749636719\" type=