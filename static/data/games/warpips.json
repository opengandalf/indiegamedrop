ps/1291010/extras/5ec8e73e5a08b732924c711e80149151.poster.avif?t=1770912777\" width=500 height=150 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1291010/extras/5ec8e73e5a08b732924c711e80149151.webm?t=1770912777\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1291010/extras/5ec8e73e5a08b732924c711e80149151.mp4?t=1770912777\" type=\"video/mp4\"></video></span><br><br><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1291010/extras/e995fe326d2a4fb6e14879477ecaa5ce.webp?t=1770912777\" width=340 height=40 /></span><br><ul class=\"bb_ul\"><li>Spawn infantry, vehicles, airplanes and helicopters<br></li><li>Call down air strikes, missile attacks and artillery<br></li><li>Units take cover and respond intelligently to their situation<br></li><li>Everything explodes!</li></ul><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1291010/extras/c10ef85e232aa7e4406d9bfd61b6bff6.poster.avif?t=1770912777\" width=500 height=150 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1291010/extras/c10ef85e232aa7e4406d9bfd61b6bff6.webm?t=1770912777\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1291010/extras/c10ef85e232aa7e4406d9bfd61b6bff6.mp4?t=1770912777\" type=\"video/mp4\"></video></span>",
