4134\" width=250 height=250 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2273220/extras/260de7766faa7629948cb549a93b0077.webm?t=1684414134\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2273220/extras/260de7766faa7629948cb549a93b0077.mp4?t=1684414134\" type=\"video/mp4\"></video></span><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2273220/extras/f23cbdee6c89154040ccb07a6f7c9171.poster.avif?t=1684414134\" width=250 height=250 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2273220/extras/f23cbdee6c89154040ccb07a6f7c9171.webm?t=1684414134\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2273220/extras/f23cbdee6c89154040ccb07a6f7c9171.mp4?t=1684414134\" type=\"video/mp4\"></video></span><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2273220/extras/09791c553bb34038556bf01dba9592f9.poster.avif?t=1684414134\" width=250 height=250 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2273220/extras/09791c553bb34038556bf01dba9592f9.webm?t=1684414134\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2273220/extras/09791c553bb34038556bf01dba9592f9.mp4?t=1684414134\" type=\"video/mp4\"></video></span><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2273220/extras/928b757a90e29d89b4b27737b00d4c77.poster.avif?t=1684414134\" width=250 height=250 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2273220/extras/928b757a90e29d89b4