  "detailed_description": "<p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1015750/extras/0b582eb83cb42cee8a17b4eeb202d946.avif?t=1749034024\" width=600 height=514 /></span></p><p class=\"bb_paragraph\" >Aisha is a happy-go-lucky thief girl. </p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" >She was on her way home after having completed a mission from the guild.</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" >However, on her way back, she was caught by the infamous Count Lugohm and his guards.</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" >What will become of Aisha?</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" >Will Aisha be able to escape from the impregnable Fortress Lugohm?</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><strong>Find out in this Stealth Survival RPG brought to you in native English!</strong></p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" >Features</p><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" ><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" >A Stealth Survival RPG Experience</p></li></ul><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" >Assassination System</p></li></ul><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" >Multiple Difficulty Levels</p></li></ul><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" >And Multiple Methods to Escape!</p></li></ul></p></li></ul>",
  "about_the_game": "<p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1015750/extras/0b582eb83cb42cee8a17b4eeb202d946.avif?t=1749034024\" width=600 height=514 /></span></p><p class=\"bb_paragraph\" >Aisha is a happy-go-lucky thief girl. </p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" >She was on her way home after having completed a mission from the guild.</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" >However, on her way back, she was caught by the infamous Count Lugohm and his guards.</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" >What will become of Aisha?</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" >Will Aisha be able to escape from the impregnable Fortress Lugohm?</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><strong>Find out in this Stealth Survival RPG brought to you in native English!</strong></p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" >Features</p><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" ><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" >A Stealth Survival RPG Experience</p></li></ul><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" >Assassination System</p></li></ul><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" >Multiple Difficulty Levels</p></li></ul><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" >And Multiple Methods to Escape!</p></li></ul></p></li></ul>",
