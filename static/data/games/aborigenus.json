line poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/611860/extras/4fe109fe87e03bb70618c5a2069daaa6.poster.avif?t=1555404788\" width=616 height=192 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/611860/extras/4fe109fe87e03bb70618c5a2069daaa6.webm?t=1555404788\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/611860/extras/4fe109fe87e03bb70618c5a2069daaa6.mp4?t=1555404788\" type=\"video/mp4\"></video></span>",
