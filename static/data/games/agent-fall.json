ras/31b92623dc99724db8e10362409ea597.webm?t=1769279112\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3220110/extras/31b92623dc99724db8e10362409ea597.mp4?t=1769279112\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" ></p><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" ><strong>Diverse environments and playabe characters.</strong></p></li></ul><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3220110/extras/efe60a75248a9c3285b785a338ef2b9b.poster.avif?t=1769279112\" width=622 height=234 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3220110/extras/efe60a75248a9c3285b785a338ef2b9b.webm?t=1769279112\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3220110/extras/efe60a75248a9c3285b785a338ef2b9b.mp4?t=1769279112\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" ></p><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" ><strong>Arsenal of Respect!</strong></p></li></ul><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3220110/extras/146cd44e2c3fc412a86a7d5b969e4e17.poster.avif?t=1769279112\" width=622 height=234 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3220110/extras/146cd44e2c3fc412a86a7d5b969e4e17.webm?t=1769279112\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3220110/extras/146cd44e2c3fc412a86a7d5b969e4e17.mp4?t=1769279112\" type=\"video/mp4\"></video></span></p>",
