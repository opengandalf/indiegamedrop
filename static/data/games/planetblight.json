item_assets/steam/apps/2205150/extras/8fc004be943c21fe68264d5f733ef1f8.poster.avif?t=1711562903\" width=450 height=300 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2205150/extras/8fc004be943c21fe68264d5f733ef1f8.webm?t=1711562903\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2205150/extras/8fc004be943c21fe68264d5f733ef1f8.mp4?t=1711562903\" type=\"video/mp4\"></video></span><br><br><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2205150/extras/9307dc99bdf4773e90b800d335134f19.webp?t=1711562903\" width=450 height=41 /></span><br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2205150/extras/a275d5e95a0192da25c1a9cc1716e303.poster.avif?t=1711562903\" width=450 height=300 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2205150/extras/a275d5e95a0192da25c1a9cc1716e303.webm?t=1711562903\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2205150/extras/a275d5e95a0192da25c1a9cc1716e303.mp4?t=1711562903\" type=\"video/mp4\"></video></span><br><br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2205150/extras/a5418c849252375fa513a514cafed841.poster.avif?t=1711562903\" width=450 height=250 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2205150/extras/a5418c849252375fa513a514cafed841.webm?t=1711562903\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2205150/extras/a5418c849252375fa513a514cafed841.mp4?t=1711562903\" type=\"video/mp4\"></video></span><br><br>While exploring the diverse terrain, players will be able to navigate up and down buildings and structures through parkour-like actions such as double-jumping, wall-running, and sliding with the help of assistive devices.<br><br>Using the various survival skills, abilities, and equipment provided, players must defend themselves against, or avoid, the people who have been dumped here by the infection and turned into looters.<br><br>Exploring, gathering resources, and protecting yourself<br><br><br>19 firearms with customisable attachments<br><br><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2205150/extras/2cf7ab2db4f69e969a4b61c68ec448ab.avif?t=1711562903\" width=128 height=128 /></span><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2205150/extras/7bb144ebf0da3a804b156534950824ff.avif?t=1711562903\" width=128 height=128 /></span><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2205150/extras/aa7da9a3156e96195150d9aea36295ea.avif?t=1711562903\" width=128 height=128 /></span><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2205150/extras/ad4ffed1ef55b0673570b653cc696f34.avif?t=1711562903\" width=128 height=128 /></span><br><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2205150/extras/5358880107cbdab9a9e6444a9b017af9.avif?t=1711562903\" width=128 height=128 /></span><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2205150/extras/2affc56996f508a76ff16117e85163e6.avif?t=1711562903\" width=128 height=128 /></span><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2205150/extras/51324cbd85123139d9a5