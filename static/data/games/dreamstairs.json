p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3336990/extras/dbc4aced07b263b60e215272710e6e8c.avif?t=1736871217\" data-big-src=https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3336990/extras_big/dbc4aced07b263b60e215272710e6e8c.avif?t=1736871217 width=800 height=450 /></span></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3336990/extras/a146d67f340018332a0b0208148afb44.avif?t=1736871217\" data-big-src=https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3336990/extras_big/a146d67f340018332a0b0208148afb44.avif?t=1736871217 width=800 height=450 /></span></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3336990/extras/62f3da0919c40e9a5c328f72108fa08e.avif?t=1736871217\" data-big-src=https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3336990/extras_big/62f3da0919c40e9a5c328f72108fa08e.avif?t=1736871217 width=800 height=450 /></span></p>",
