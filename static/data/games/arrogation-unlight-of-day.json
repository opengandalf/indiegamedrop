steam/apps/2113530/extras/050657187b58befaf96389e1063c3515.webm?t=1677158174\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2113530/extras/050657187b58befaf96389e1063c3515.mp4?t=1677158174\" type=\"video/mp4\"></video></span><br><br><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2113530/extras/f9af5e7e5c57202bd4e330133947f221.avif?t=1677158174\" width=615 height=79 /></span><br><br>Being in a gloomy and crisis-filled village, you must use all possible means to escape from here. Explore carefully in order to escape.<br><br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2113530/extras/0c59402096906a73263928c7a69e56b6.poster.avif?t=1677158174\" width=614 height=300 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2113530/extras/0c59402096906a73263928c7a69e56b6.webm?t=1677158174\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2113530/extras/0c59402096906a73263928c7a69e56b6.mp4?t=1677158174\" type=\"video/mp4\"></video></span><br><br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2113530/extras/6cc3d7d290811adaf70f95a6374c7ae5.poster.avif?t=1677158174\" width=614 height=250 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2113530/extras/6cc3d7d290811adaf70f95a6374c7ae5.webm?t=1677158174\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2113530/extras/6cc3d7d290811adaf70f95a6374c7ae5.mp4?t=1677158174\" type=\"video/mp4\"></video></span><br><br><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akama