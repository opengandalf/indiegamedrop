/apps/2180060/extras/e818b1debc961ca3101f8637f942190d.webm?t=1714700014\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2180060/extras/e818b1debc961ca3101f8637f942190d.mp4?t=1714700014\" type=\"video/mp4\"></video></span></li><li>Breezy Field Farms<br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2180060/extras/2642431058037466371422f2bfb55053.poster.avif?t=1714700014\" width=600 height=338 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2180060/extras/2642431058037466371422f2bfb55053.webm?t=1714700014\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2180060/extras/2642431058037466371422f2bfb55053.mp4?t=1714700014\" type=\"video/mp4\"></video></span></li><li>Abducted Laboratories<br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2180060/extras/b0074ae09fd1bdf85b41ba23eab5876a.poster.avif?t=1714700014\" width=600 height=338 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2180060/extras/b0074ae09fd1bdf85b41ba23eab5876a.webm?t=1714700014\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2180060/extras/b0074ae09fd1bdf85b41ba23eab5876a.mp4?t=1714700014\" type=\"video/mp4\"></video></span><br><br><ul class=\"bb_ul\"><li>Enjoy the beautiful weather!<br></li><li>Try some of our locally grown food, fresh from farm to table!<br></li><li>View our award-winning news coverage!</li></ul><br><i>Enjoy your trip!</i><br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2180060/extras/58646196d1