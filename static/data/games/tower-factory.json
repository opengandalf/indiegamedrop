th=600 height=200 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2707490/extras/ead64c004f9dcaa55a5e2da14e084d0a.webm?t=1773400999\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2707490/extras/ead64c004f9dcaa55a5e2da14e084d0a.mp4?t=1773400999\" type=\"video/mp4\"></video></span></p>",
