3752cd05ceb9c2e5add5f2f8.webm?t=1687879725\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1955330/extras/94bb26673752cd05ceb9c2e5add5f2f8.mp4?t=1687879725\" type=\"video/mp4\"></video></span><br><br><strong>Reload your weapons:</strong><br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1955330/extras/c2c4f7b833efeb490ba6d779f65ade0a.poster.avif?t=1687879725\" width=640 height=360 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1955330/extras/c2c4f7b833efeb490ba6d779f65ade0a.webm?t=1687879725\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1955330/extras/c2c4f7b833efeb490ba6d779f65ade0a.mp4?t=1687879725\" type=\"video/mp4\"></video></span><br><br><strong>Combine herbs to make porwerfull healling itens:</strong><br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1955330/extras/d8e3d70e5e3f6adb9f2e8df639978228.poster.avif?t=1687879725\" width=640 height=360 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1955330/extras/d8e3d70e5e3f6adb9f2e8df639978228.webm?t=1687879725\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1955330/extras/d8e3d70e5e3f6adb9f2e8df639978228.mp4?t=1687879725\" type=\"video/mp4\"></video></span><br><br><strong>Combine gunpowders to create ammo:</strong><br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1955330/extras/a0baca6274ba3834124ce9c2f06d4dd1.poster.avif?t=1687879725\" width=640 height=360 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1955330/extras/a0baca6274ba3834124ce9c2f06d4dd1.webm?t=1687879725\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1955330/extras/a0baca6274ba3834124ce9c2f06d4dd1.mp4?t=1687879725\" type=\"video/mp4\"></video></span><h2 class=\"bb_tag\" >Features</h2><ul class=\"bb_ul\"><li><strong><strong>Use your organizing skills to make all your items fit. </strong></strong><br></li><li><strong>Use your logical thinking to use the items in the right order to free some spaces.</strong><br></li><li><strong>Understand the format of several items to find the best fitting.</strong><br></li><li><strong>40 unique handmade levels.</strong><br></li><li><strong>Relaxing music and sound effects made for the game!    </strong></li></ul>",
