/steam/apps/2065810/extras/452848ba38c4ccfad26936266e0d61f7.poster.avif?t=1725017058\" width=600 height=338 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2065810/extras/452848ba38c4ccfad26936266e0d61f7.webm?t=1725017058\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2065810/extras/452848ba38c4ccfad26936266e0d61f7.mp4?t=1725017058\" type=\"video/mp4\"></video></span><br><br><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2065810/extras/5f328c3bbf62c2080ea2865369582726.webp?t=1725017058\" width=616 height=57 /></span><br>Gain powerful items to increase your might and the power of your army.<br><br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2065810/extras/1511d91b619efb586a35666cb1493337.poster.avif?t=1725017058\" width=600 height=338 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2065810/extras/1511d91b619efb586a35666cb1493337.webm?t=1725017058\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2065810/extras/1511d91b619efb586a35666cb1493337.mp4?t=1725017058\" type=\"video/mp4\"></video></span><br><br><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2065810/extras/001a00c5c4137b451eab5be4fe1c8e96.webp?t=1725017058\" width=616 height=57 /></span><br>Explore, conquer, and take back the souls the living stole from you.<br><br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2065810/extras/7af4e76784ed684c7cf25d8f5362a443.poster.avif?t=1725017058\" width=600 height=338 ><source src=\"https://shared.akamai.s