g_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/854860/extras/2968e43673ca0e7ca35f0a1f5f7f2075.poster.avif?t=1594771649\" width=628 height=182 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/854860/extras/2968e43673ca0e7ca35f0a1f5f7f2075.webm?t=1594771649\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/854860/extras/2968e43673ca0e7ca35f0a1f5f7f2075.mp4?t=1594771649\" type=\"video/mp4\"></video></span></li></ul>",
