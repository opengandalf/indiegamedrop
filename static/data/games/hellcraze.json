a46d55353ac7ef756ee0100dcd94d676.webm?t=1634323793\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1439460/extras/a46d55353ac7ef756ee0100dcd94d676.mp4?t=1634323793\" type=\"video/mp4\"></video></span><br><br>Feast on their soul and upgrade your gear to get stronger!<br><br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1439460/extras/915d6edd872a5126a022a45c069af96e.poster.avif?t=1634323793\" width=800 height=360 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1439460/extras/915d6edd872a5126a022a45c069af96e.webm?t=1634323793\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1439460/extras/915d6edd872a5126a022a45c069af96e.mp4?t=1634323793\" type=\"video/mp4\"></video></span>",
