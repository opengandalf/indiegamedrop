i></ul><br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1273940/extras/d1efab6a1d0d12dd75debde37f762142.poster.avif?t=1744035113\" width=600 height=276 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1273940/extras/d1efab6a1d0d12dd75debde37f762142.webm?t=1744035113\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1273940/extras/d1efab6a1d0d12dd75debde37f762142.mp4?t=1744035113\" type=\"video/mp4\"></video></span>",
