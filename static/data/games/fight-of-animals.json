d loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1160330/extras/84089b4a6d6c06e918cabad16b8e9cd9.poster.avif?t=1732008563\" width=600 height=338 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1160330/extras/84089b4a6d6c06e918cabad16b8e9cd9.webm?t=1732008563\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1160330/extras/84089b4a6d6c06e918cabad16b8e9cd9.mp4?t=1732008563\" type=\"video/mp4\"></video></span></p>",
