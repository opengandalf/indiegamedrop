1eae1f1dc7.webm?t=1747979132\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3391350/extras/0158b7502f880aa3e3db3f1eae1f1dc7.mp4?t=1747979132\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" >there is no light left in here, and you can barely see anything. <br>the only way to see more is using echolocation. make noise, see your surroundings. make louder noise, see even more. but don't be<i> too loud</i>. just in case.</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" >you're not the only one in here. even if you think you are, you probably are not. but if you're too tired of this stupid bird alongside you, you can just push them off. you're the one who's leading here, are you not?</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3391350/extras/6ecc11f35ed4f1f4057ce88ceebbfd33.poster.avif?t=1747979132\" width=800 height=362 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3391350/extras/6ecc11f35ed4f1f4057ce88ceebbfd33.webm?t=1747979132\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3391350/extras/6ecc11f35ed4f1f4057ce88ceebbfd33.mp4?t=1747979132\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" ></p><h2 class=\"bb_tag\" >features:</h2><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" >peculiar pitch dark world</p></li><li><p class=\"bb_paragraph\" >platforming puzzles with different approaches - either help each other or consume the chocolate and go by yourself</p></li><li><p class=\"bb_paragraph\" >smooth platforming controller capable of b-hop and surfing</p></li><li><p class=\"bb_paragraph\" >online co-op (or for some people it might even be pvp) up to 100 players in a lobby (it doesnt perform well with 100 players but you can try it. if you do, record and post it please) with player interactions</p></li><li><p class=\"bb_paragraph\" >stylized crunchy graphics</p></li><li><p class=\"bb_paragraph\" >evil game design</p></li><li><p class=\"bb_paragraph\" >the void</p></li></ul>",
