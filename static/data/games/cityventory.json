    "https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3457830/f5ecd9cae55ac3906b6643bd57772b6151d4bad0/ss_f5ecd9cae55ac3906b6643bd57772b6151d4bad0.600x338.jpg?t=1746968140"
