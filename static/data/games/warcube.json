ay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/505060/extras/fde5a9828570d6958fdd4be475eaea64.poster.avif?t=1672331634\" width=664 height=374 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/505060/extras/fde5a9828570d6958fdd4be475eaea64.webm?t=1672331634\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/505060/extras/fde5a9828570d6958fdd4be475eaea64.mp4?t=1672331634\" type=\"video/mp4\"></video></span><br><br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/505060/extras/8583207f719f5e3e226d44369812bd98.poster.avif?t=1672331634\" width=610 height=344 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/505060/extras/8583207f719f5e3e226d44369812bd98.webm?t=1672331634\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/505060/extras/8583207f719f5e3e226d44369812bd98.mp4?t=1672331634\" type=\"video/mp4\"></video></span>",
