r=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1479480/extras/adafa7c82a4b7de9b59db70df2012fb0.poster.avif?t=1724830804\" width=600 height=200 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1479480/extras/adafa7c82a4b7de9b59db70df2012fb0.webm?t=1724830804\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1479480/extras/adafa7c82a4b7de9b59db70df2012fb0.mp4?t=1724830804\" type=\"video/mp4\"></video></span><br><strong>See you in BD2!</strong><br><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1479480/extras/f92e79e13e3d8d0c22ccb8ea2267dd1c.avif?t=1724830804\" width=600 height=200 /></span>",
