    "https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/914750/ss_13797eaddc95437dcd2a4a2775b335a71675ee3a.600x338.jpg?t=1774024612",
    "https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/914750/ss_4174dbbb2f73806f2401a359ec982f13e2047903.600x338.jpg?t=1774024612"
