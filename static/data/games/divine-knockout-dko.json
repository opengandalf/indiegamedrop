ed.akamai.steamstatic.com/store_item_assets/steam/apps/1294660/extras/aa7260cd728dbb6ddd54789d0166fe4e.mp4?t=1739811739\" type=\"video/mp4\"></video></span>With full cross-play and cross-progression, you can play anyone, anywhere.</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1294660/extras/e6bc8ce48cb9cb4fc137879b5ecfb379.poster.avif?t=1739811739\" width=624 height=100 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1294660/extras/e6bc8ce48cb9cb4fc137879b5ecfb379.webm?t=1739811739\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1294660/extras/e6bc8ce48cb9cb4fc137879b5ecfb379.mp4?t=1739811739\" type=\"video/mp4\"></video></span>Customize each god to play exactly how you want, and to show your unique style.</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1294660/extras/91c5d306f682e33840f28eca8ead10b0.poster.avif?t=1739811739\" width=624 height=100 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1294660/extras/91c5d306f682e33840f28eca8ead10b0.webm?t=1739811739\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1294660/extras/91c5d306f682e33840f28eca8ead10b0.mp4?t=1739811739\" type=\"video/mp4\"></video></span>New gods, maps, cosmetics, and modes are released regularly.</p>",
