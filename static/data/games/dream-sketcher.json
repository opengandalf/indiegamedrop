ockable investigator.<br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2168810/extras/90a69faf29fec4d051f0eb89ca6331d9.poster.avif?t=1705297849\" width=628 height=182 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2168810/extras/90a69faf29fec4d051f0eb89ca6331d9.webm?t=1705297849\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2168810/extras/90a69faf29fec4d051f0eb89ca6331d9.mp4?t=1705297849\" type=\"video/mp4\"></video></span>",
