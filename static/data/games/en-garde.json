    "https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1654660/ss_c3b74a05f806100e767020eb27cd4e836abb5fad.600x338.jpg?t=1732721748",
    "https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1654660/ss_28807894744ac8239d036f684a308302bcfef35f.600x338.jpg?t=1732721748"
