ic.com/store_item_assets/steam/apps/1493880/extras/c60a684824df720452b6816e6c0d90f1.webm?t=1731304132\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1493880/extras/c60a684824df720452b6816e6c0d90f1.mp4?t=1731304132\" type=\"video/mp4\"></video></span><br><br><br><br><br>",
