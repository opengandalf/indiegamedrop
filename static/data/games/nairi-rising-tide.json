 src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1225200/extras/eb300f9f04425475c47828b1ed5ccb3c.mp4?t=1740571304\" type=\"video/mp4\"></video></span><br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1225200/extras/e5147e470740b01bb7ebc1aa7248f5e9.poster.avif?t=1740571304\" width=480 height=270 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1225200/extras/e5147e470740b01bb7ebc1aa7248f5e9.webm?t=1740571304\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1225200/extras/e5147e470740b01bb7ebc1aa7248f5e9.mp4?t=1740571304\" type=\"video/mp4\"></video></span><h2 class=\"bb_tag\" >Explore, Collect & Craft</h2>Explore the oasis city of Shirin to meet cute, wacky and even dangerous characters!<br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1225200/extras/cdcf02b9a7e459fbe4c45f735541b58e.poster.avif?t=1740571304\" width=480 height=270 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1225200/extras/cdcf02b9a7e459fbe4c45f735541b58e.webm?t=1740571304\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1225200/extras/cdcf02b9a7e459fbe4c45f735541b58e.mp4?t=1740571304\" type=\"video/mp4\"></video></span><br>Find items and combine them in interesting ways!<br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1225200/extras/872c5f7e932c78e3514580110b2cda9a.poster.avif?t=1740571304\" width=480 height=270 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1225200/extras/872c5f7e932c78e3514580110b2cda9a.webm?t=1740571304\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1225200/extras/872c5f7e932c78e3514580110b2cda9a.mp4?t=1740571304\" type=\"video/mp4\"></video></span><h2 class=\"bb_tag\" >Challenging Puzzles</h2>Solve your way through the many puzzles of Shirin!<br>You may even encounter a 'puzzle-dungeon' - a complex space filled with interconnected puzzles which will pose a true challenge.<br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1225200/extras/8cef46a0ad0e81320e00574030e7ff91.poster.avif?t=1740571304\" width=480 height=270 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1225200/extras/8cef46a0ad0e81320e00574030e7ff91.webm?t=1740571304\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1225200/extras/8cef46a0ad0e81320e00574030e7ff91.mp4?t=1740571304\" type=\"video/mp4\"></video></span><br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1225200/extras/19cbfab9950a0b79eb55e6f76b7f6fb9.poster.avif?t=1740571304\" width=480 height=270 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1225200/extras/19cbfab9950a0b79eb55e6f76b7f6fb9.webm?t=1740571304\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1225200/extras/19cbfab9950a0b79eb55e6f76b7f6fb9.mp4?t=1740571304\" type=\"video/mp4\"></video></span><h2 class=\"bb_tag\" >The Cutest Hint System</h2>Spend coins on hints ranging from nudges to complete solutions.<br>And if you're just here for the story, you may even skip entire puzzle-dungeons!<br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1225200/extras/4130feacbe45a799db795f27ff4ee265.poster.avif?t=1740571304\" width=480 height=270 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1225200/extras/4130feacbe45a799db795f27ff4ee265.webm?t=1740571304\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1225200/extras/4130feacbe45a799db795f27ff4ee265.mp4?t=1740571304\" type=\"video/mp4\"></video></span><h2 class=\"bb_tag\" >Maps & Fast-Travel</h2>Not sure where you are or where to go? Use the map!<br>Be sure to use fast-travel if you don't feel like backtracking.<br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1225200/extras/fd4d6ca476b76ded01f15fb479708a1a.poster.avif?t=1740571304\" width=480 height=270 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1225200/extras/fd4d6ca476b76ded01f15fb479708a1a.webm?t=1740571304\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1225200/extras/fd4d6ca476b76ded01f15fb479708a1a.mp4?t=1740571304\" type=\"video/mp4\"></video></span><br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1225200/extras/061a5b6349f65805fd0d340f6507e12e.poster.avif?t=1740571304\" width=480 height=270 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1225200/extras/061a5b6349f65805fd0d340f6507e12e.webm?t=1740571304\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1225200/extras/061a5b6349f65805fd0d340f6507e12e.mp4?t=1740571304\" type=\"video/mp4\"></video></span><h2 class=\"bb_tag\" >Collectibles!</h2>Collect coins, recruit chara