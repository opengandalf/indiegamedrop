d89f8c4cb9a2158ab6b9ed0b0072f3e.mp4?t=1672994143\" type=\"video/mp4\"></video></span><br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2000560/extras/22d474e457c52448c5287d0cc3be627c.poster.avif?t=1672994143\" width=378 height=218 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2000560/extras/22d474e457c52448c5287d0cc3be627c.webm?t=1672994143\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2000560/extras/22d474e457c52448c5287d0cc3be627c.mp4?t=1672994143\" type=\"video/mp4\"></video></span><br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2000560/extras/dda20e3af3f0924ee7f8d5f8026f0fea.poster.avif?t=1672994143\" width=556 height=224 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2000560/extras/dda20e3af3f0924ee7f8d5f8026f0fea.webm?t=1672994143\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2000560/extras/dda20e3af3f0924ee7f8d5f8026f0fea.mp4?t=1672994143\" type=\"video/mp4\"></video></span><br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2000560/extras/c61e8424203ffbfb8f172d5d63d973f5.poster.avif?t=1672994143\" width=568 height=320 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2000560/extras/c61e8424203ffbfb8f172d5d63d973f5.webm?t=1672994143\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2000560/extras/c61e8424203ffbfb8f172d5d63d973f5.mp4?t=1672994143\" type=\"video/mp4\"></video></span>",
