extras/e8826ff4ea66219a8d783f3a773f152c.poster.avif?t=1705277174\" width=690 height=388 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2515290/extras/e8826ff4ea66219a8d783f3a773f152c.webm?t=1705277174\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2515290/extras/e8826ff4ea66219a8d783f3a773f152c.mp4?t=1705277174\" type=\"video/mp4\"></video></span>",
