atic.com/store_item_assets/steam/apps/2860170/extras/6b36832e72af4399105f0141a0781e94.mp4?t=1765341494\" type=\"video/mp4\"></video></span></p></li><li><p class=\"bb_paragraph\" ><strong>Unlockable Content</strong>: Discover <span class=\"bb_strike\">8</span> now 9! charming skins and conquer 4 captivating mini-games: Memory, Tic-Tac-Toe, Dance Party, and Spire Run. <br>    </p></li><li><p class=\"bb_paragraph\" ><strong>Rewarding System</strong>: Spend Stars to unlock exciting new skins and mini-games, or keep hold of them to push up your daily high score. Check in each day to beat your high scores for Stars and each mini-game. </p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2860170/extras/1c6d6221e8f29f2534ab23999b4eb2a0.poster.avif?t=1765341494\" width=620 height=448 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2860170/extras/1c6d6221e8f29f2534ab23999b4eb2a0.webm?t=1765341494\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2860170/extras/1c6d6221e8f29f2534ab23999b4eb2a0.mp4?t=1765341494\" type=\"video/mp4\"></video></span></p></li><li><p class=\"bb_paragraph\" ><strong>Intuitive Controls</strong>: Enjoy seamless game-play with touchscreen, mouse, or keyboard inputs, including support for controllers. </p></li><li><p class=\"bb_paragraph\" ><strong>Original Pixel Art</strong>: Immerse yourself in the game's enchanting world, crafted with love in Aseprite.</p></li></ul><h2 class=\"bb_tag\" > Developers</h2><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" >Graphics and Game Design - Nicole Haynie</p><p class=\"bb_paragraph\" >Original Sound Track - Silly Little Muse sillylittlemuse on Linktree</p><p class=\"bb_paragraph\" >Sound Effects - Wesley Barros @wbaudio on X</p>",
