/steam/apps/384300/extras/f97cc9dfe7d5b1e3a5e8cbd3a8304b24.poster.avif?t=1739668443\" width=460 height=600 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/384300/extras/f97cc9dfe7d5b1e3a5e8cbd3a8304b24.webm?t=1739668443\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/384300/extras/f97cc9dfe7d5b1e3a5e8cbd3a8304b24.mp4?t=1739668443\" type=\"video/mp4\"></video></span><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/384300/extras/3ea255f3efe3775a9681c7850da850dd.avif?t=1739668443\" width=450 height=612 /></span><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/384300/extras/c24146468880e4c3663ce99191953a02.avif?t=1739668443\" width=450 height=612 /></span><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/384300/extras/966d4e086d737a3159cd83b2fb97356c.avif?t=1739668443\" width=450 height=612 /></span><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/384300/extras/f54c2006bd4b7bf1e3c00da6bddfbc65.avif?t=1739668443\" width=450 height=612 /></span><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/384300/extras/15ddabeb7413dd307176788c2821ed18.avif?t=1739668443\" width=450 height=612 /></span><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/384300/extras/2fb107c57e4b05883f2e7425e83dc2bb.avif?t=1739668443\" width=450 height=612 /></span><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/384300/extras/27f3e9f538130a9c1b4d6c2442c8225f.avif?t=1739668443\" width=450 height=612 /></spa