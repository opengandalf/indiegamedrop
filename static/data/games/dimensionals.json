f6b6cd51c79cf0c4a2.webm?t=1746057103\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2856450/extras/4b13ea63dced3df6b6cd51c79cf0c4a2.mp4?t=1746057103\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2856450/extras/a18b54d7604871767e5505df3644b6ef.poster.avif?t=1746057103\" width=616 height=348 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2856450/extras/a18b54d7604871767e5505df3644b6ef.webm?t=1746057103\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2856450/extras/a18b54d7604871767e5505df3644b6ef.mp4?t=1746057103\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" >The Master Raid is the ultimate roguelike test of your strategy skills! </p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" >Fight your way through each of Ragnarath’s world crushing bosses, encounter the Mysterious Rogue Rifters, and take the fight to Ragnarath himself! Manage powerful blessings and brutal curses, and watch out! It will wake everything you have to beat this endlessly replayable roguelike challenge!</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2856450/extras/e5840f2093a101ee7a87db7d287d8e94.poster.avif?t=1746057103\" width=616 height=104 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2856450/extras/e5840f2093a101ee7a87db7d287d8e94.webm?t=1746057103\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2856450/extras/e5840f2093a101ee7a87db7d287d8e94.mp4?t=1746057103\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2856450/extras/dcae41073c4a8049346240b175a50943.poster.avif?t=1746057103\" width=616 height=348 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2856450/extras/dcae41073c4a8049346240b175a50943.webm?t=1746057103\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2856450/extras/dcae41073c4a8049346240b175a50943.mp4?t=1746057103\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" >Get hooked on your new favorite characters! There are tons of heroes to unlock, each with their own classic RPG level tree. Experience their voice-acted personalities and backstories as they fight alongside you in the campaign.  </p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" >Only once you have assembled the Dimensionals can you defeat Ragnarath!</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2856450/extras/235c564e6b5534084c85024dd826fa1b.poster.avif?t=1746057103\" width=616 height=104 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2856450/extras/235c564e6b5534084c85024dd826fa1b.webm?t=1746057103\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2856450/extras/235c564e6b5534084c85024dd826fa1b.mp4?t=1746057103\" type=\"video/mp4\"></video></span></p><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" ><strong>Collect tons of Heroes</strong> - Each with their own unique skills & gameplay, with more heroes being added throughout Early Access, there are endless party combinations to make! </p></li><li><p class=\"bb_paragraph\" ><strong>Level up your Heroes</strong> -  Earn XP, level up, assign skill points and unlock the legendary skills!</p></li><li><p class=\"bb_paragraph\" ><strong>Equippable skills</strong> - Move skills between heroes, adjust strategies, and create endless unique builds on the fly!</p></li><li><p class=\"bb_paragraph\" ><strong>Comic book Campaign</strong> - Play through an incredible adventure to save the world… complete with  voice acted, animated comic book cutscenes!</p></li><li><p class=\"bb_paragraph\" ><strong>Endless Replayability</strong> - Procedurally generated encounters that keep even the mightiest of heroes on their toes.</p></li><li><p class=\"bb_paragraph\" ><strong>Insane bosses</strong> - They’re big! They’re bad! They’re the ultimate challenge for your heroes each with hand animated cartoon attacks!</p></li><li><p class=\"bb_paragraph\" ><strong>Cartoon soundtrack by Brad Breek</strong> - Guaranteed to get stuck in your head! Reminiscent of the catchiest theme songs from Saturday Morning Cartoons. From the composer of Gravity Falls.</p></li><li><p class=\"bb_paragraph\" ><strong>Rogue Rifters</strong> - A nefarious group of mysterious characters who live in the Rift. Here to help you out… for a price! </p></li><li><p class=\"bb_paragraph\" ><strong>Artifacts</strong> - Legendary artifacts discarded in the Rift grant your heroes powerful blessings—or equally devastating curses!</p></li><li><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2856450/extras/d84df2910eccd8b998a60df540a4ff46.poster.avif?t=1746057103\" width=616 height=348 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2856450/extras/d84df2910eccd8b998a60df540a4ff46.webm?t=1746057103\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2856450/extras/d84df2910eccd8b998a60df540a4ff46.mp4?t=1746057103\" type=\"video/mp4\"></video></span></p></li></ul><p class=\"bb_paragraph\" > </p><p class=\"bb_paragraph\" ></p>",
