ai.steamstatic.com/store_item_assets/steam/apps/1465460/extras/765c01ecaf5c0621d9dc6927fe02fb51.webm?t=1772194631\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1465460/extras/765c01ecaf5c0621d9dc6927fe02fb51.mp4?t=1772194631\" type=\"video/mp4\"></video></span></p>",
