ysinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1521580/extras/c854f9d9399d3f1cd9a29c2aef70205c.poster.avif?t=1773976463\" width=600 height=338 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1521580/extras/c854f9d9399d3f1cd9a29c2aef70205c.webm?t=1773976463\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1521580/extras/c854f9d9399d3f1cd9a29c2aef70205c.mp4?t=1773976463\" type=\"video/mp4\"></video></span>",
