source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1273380/extras/4f73bce3f49171f30582ae5a0179b143.webm?t=1765219559\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1273380/extras/4f73bce3f49171f30582ae5a0179b143.mp4?t=1765219559\" type=\"video/mp4\"></video></span>",
