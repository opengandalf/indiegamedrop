re_item_assets/steam/apps/2069920/extras/0e4a998d6df21d88d9d5a230b7adf0a6.webm?t=1687644044\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2069920/extras/0e4a998d6df21d88d9d5a230b7adf0a6.mp4?t=1687644044\" type=\"video/mp4\"></video></span>",
